  },

  tdTeam: {
    padding: "6px 3px",
    borderTop: "1px solid rgba(255,255,255,0.06)",
    fontSize: 12,
    whiteSpace: "nowrap",
    overflow: "hidden",
    textOverflow: "ellipsis",
  },

  tdMini: {
    padding: "6px 3px",
    borderTop: "1px solid rgba(255,255,255,0.06)",
