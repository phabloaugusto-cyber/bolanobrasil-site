"use client";

import { useEffect, useMemo, useState } from "react";
import Link from "next/link";
import {
  buildLiveStandingsFromOfficial,
  hasLiveMatches,
} from "@/lib/classificacao-ao-vivo";

function traduzirStatus(status) {
  switch (status) {
    case "TIMED":
    case "SCHEDULED":
      return "Agendado";
    case "LIVE":
      return "Ao vivo";
    case "IN_PLAY":
      return "Em andamento";
    case "PAUSED":
      return "Intervalo";
    case "POSTPONED":
      return "Adiado";
    case "FINISHED":
      return "Encerrado";
    case "CANCELED":
      return "Cancelado";
    default:
      return status || "—";
  }
}

function formatarDataHoraBrasil(dateString) {
  try {
    return new Intl.DateTimeFormat("pt-BR", {
      timeZone: "America/Sao_Paulo",
      day: "2-digit",
      month: "2-digit",
      year: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    }).format(new Date(dateString));
  } catch {
    return "--/--/---- --:--";
  }
}

export default function TabelaPage() {
  const [table, setTable] = useState([]);
  const [matches, setMatches] = useState([]);
  const [round, setRound] = useState(1);
  const [loading, setLoading] = useState(true);
  const [err, setErr] = useState("");

  useEffect(() => {
    async function load() {
      try {
        setLoading(true);
        setErr("");

        const [tableRes, matchesRes] = await Promise.all([
          fetch("/api/standings?competition=BSA&season=2026", { cache: "no-store" }),
          fetch("/api/matches?competition=BSA&season=2026", { cache: "no-store" }),
        ]);

        if (!tableRes.ok) throw new Error("Erro ao carregar tabela");
        if (!matchesRes.ok) throw new Error("Erro ao carregar jogos");

        const tableData = await tableRes.json();
        const matchesData = await matchesRes.json();

        const total = tableData?.standings?.find((s) => s.type === "TOTAL");
        const tableRows = total?.table || [];
        const allMatches = matchesData?.matches || [];

        setTable(tableRows);
        setMatches(allMatches);

        const rounds = [...new Set(allMatches.map((m) => m.matchday).filter(Boolean))].sort(
          (a, b) => a - b
        );

        const now = new Date();

        const nextScheduledMatch = allMatches
          .filter((m) => m.utcDate && new Date(m.utcDate) > now)
          .sort((a, b) => new Date(a.utcDate) - new Date(b.utcDate))[0];

        if (nextScheduledMatch?.matchday) {
          setRound(nextScheduledMatch.matchday);
        } else if (rounds.length) {
          setRound(rounds[rounds.length - 1]);
        }
      } catch (e) {
        setErr(e?.message || "Erro");
      } finally {
        setLoading(false);
      }
    }

    load();
  }, []);
const existeJogoAoVivo = useMemo(() => {
    return hasLiveMatches(matches || []);
  }, [matches]);

  const tabelaExibicao = useMemo(() => {
    return buildLiveStandingsFromOfficial(table || [], matches || []);
  }, [table, matches]);
  const rounds = useMemo(() => {
    return [...new Set(matches.map((m) => m.matchday).filter(Boolean))].sort((a, b) => a - b);
  }, [matches]);

  const roundMatches = useMemo(() => {
    return matches
      .filter((m) => m.matchday === round)
      .sort((a, b) => new Date(a.utcDate) - new Date(b.utcDate));
  }, [matches, round]);

  return (
    <div style={styles.page}>
      <div style={styles.topbar}>
        <div>
          <h1 style={styles.title}>Tabela do Brasileirão Série A 2026</h1>
          <p style={styles.lead}>
            Confira a classificação atualizada do Brasileirão, com pontuação,
            jogos, vitórias, empates, derrotas, gols pró, gols contra, saldo de gols
            e os jogos por rodada.
          </p>
        </div>

        <Link href="/" style={styles.linkBtn}>
          ← Voltar Home
        </Link>
      </div>

      {loading ? (
        <div style={styles.card}>Carregando…</div>
      ) : err ? (
        <div style={styles.card}>
          <div style={{ color: "#ffb4b4" }}>{err}</div>
        </div>
      ) : (
        <>
          <section style={styles.card}>
            <h2 style={styles.sectionTitle}>Classificação completa do Brasileirão</h2>

            <div style={styles.tableWrap}>
              <table style={styles.table}>
                <colgroup>
                  <col style={{ width: "22px" }} />
                  <col style={{ width: "160px" }} />
                  <col style={{ width: "26px" }} />
                  <col style={{ width: "26px" }} />
                  <col style={{ width: "26px" }} />
                  <col style={{ width: "26px" }} />
                  <col style={{ width: "26px" }} />
                  <col style={{ width: "30px" }} />
                  <col style={{ width: "30px" }} />
                  <col style={{ width: "30px" }} />
                </colgroup>

                <thead>
                  <tr>
                    <th style={styles.thNum}>#</th>
                    <th style={styles.thTeam}>Time</th>
                    <th style={styles.thMini}>P</th>
                    <th style={styles.thMini}>J</th>
                    <th style={styles.thMini}>V</th>
                    <th style={styles.thMini}>E</th>
                    <th style={styles.thMini}>D</th>
                    <th style={styles.thMini}>GP</th>
                    <th style={styles.thMini}>GC</th>
                    <th style={styles.thMini}>SG</th>
                  </tr>
                </thead>

                <tbody>
                    {tabelaExibicao.map((t) => (
                    <tr key={t.team.id} style={rowColor(t.position)}>
                      <td style={styles.tdNum}>{t.position}</td>

                      <td style={styles.tdTeam}>
                        <img
                          src={t.team.crest}
                          alt={`Escudo do ${t.team.shortName || t.team.name}`}
                          style={styles.crest}
                        />
                        <span style={styles.teamName}>
                          {t.team.shortName || t.team.name}
                        </span>
                      </td>

                      <td style={styles.tdMini}>
                        <b>{t.points}</b>
                      </td>
                      <td style={styles.tdMini}>{t.playedGames}</td>
                      <td style={styles.tdMini}>{t.won}</td>
                      <td style={styles.tdMini}>{t.draw}</td>
                      <td style={styles.tdMini}>{t.lost}</td>
                      <td style={styles.tdMini}>{t.goalsFor}</td>
                      <td style={styles.tdMini}>{t.goalsAgainst}</td>
                      <td style={styles.tdMini}>{t.goalDifference}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>

          <section style={styles.card}>
            <div style={styles.roundHeader}>
              <h2 style={styles.sectionTitle}>Jogos por rodada do Brasileirão</h2>
               {existeJogoAoVivo ? (
              <p style={styles.liveInfo}>
                Classificação ao vivo: a tabela muda conforme os gols dos jogos em andamento.
              </p>
            ) : null}

              <select
                value={round}
                onChange={(e) => setRound(Number(e.target.value))}
                style={styles.select}
              >
                {rounds.map((r) => (
                  <option key={r} value={r}>
                    Rodada {r}
                  </option>
                ))}
              </select>
            </div>

            <div style={styles.roundStrip}>
              {rounds.map((r) => (
                <button
                  key={r}
                  onClick={() => setRound(r)}
                  style={r === round ? styles.roundBtnActive : styles.roundBtn}
                >
                  {r}
                </button>
              ))}
            </div>

            <div style={styles.list}>
              {roundMatches.map((m) => (
                <div key={m.id} style={styles.matchCard}>
                  <div style={styles.matchMeta}>
                    <span>{formatarDataHoraBrasil(m.utcDate)}</span>
                    <span style={styles.statusPill}>{traduzirStatus(m.status)}</span>
                  </div>

                  <div style={styles.scoreLine}>
                    <img
                      src={m.homeTeam?.crest}
                      alt={`Escudo do ${m.homeTeam?.shortName || m.homeTeam?.name}`}
                      style={styles.crestSm}
                    />
                    <span style={styles.teamLabel}>
                      {m.homeTeam?.shortName || m.homeTeam?.name}
                    </span>
                    <span style={styles.scoreNum}>
                      {m.score?.fullTime?.home ?? m.score?.halfTime?.home ?? "-"}
                    </span>
                  </div>

                  <div style={styles.scoreLine}>
                    <img
                      src={m.awayTeam?.crest}
                      alt={`Escudo do ${m.awayTeam?.shortName || m.awayTeam?.name}`}
                      style={styles.crestSm}
                    />
                    <span style={styles.teamLabel}>
                      {m.awayTeam?.shortName || m.awayTeam?.name}
                    </span>
                    <span style={styles.scoreNum}>
                      {m.score?.fullTime?.away ?? m.score?.halfTime?.away ?? "-"}
                    </span>
                  </div>
                </div>
              ))}

              {!roundMatches.length && (
                <div style={styles.emptyBox}>
                  Nenhum jogo encontrado para esta rodada no momento.
                </div>
              )}
            </div>
          </section>
        </>
      )}
    </div>
  );
}

function rowColor(pos) {
  if (pos >= 1 && pos <= 4) return { background: "rgba(0,140,255,0.10)" };
  if (pos >= 5 && pos <= 6) return { background: "rgba(0,140,255,0.06)" };
  if (pos >= 17 && pos <= 20) return { background: "rgba(255,80,80,0.10)" };
  return {};
}

const styles = {
