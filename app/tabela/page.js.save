    fontSize: 12,
  },

  crest: {
    width: 18,
    height: 18,
    borderRadius: 6,
    marginRight: 4,
    verticalAlign: "middle",
    objectFit: "contain",
  },

  teamName: {
    verticalAlign: "middle",
  },

  roundHeader: {
    display: "flex",
    justifyContent: "space-between",
    alignItems: "center",
    gap: 10,
    flexWrap: "wrap",
    marginBottom: 8,
  },

  select: {
    padding: "8px 10px",
    borderRadius: 10,
    background: "rgba(255,255,255,0.06)",
    border: "1px solid rgba(255,255,255,0.12)",
    color: "#e6edf3",
  },

  roundStrip: {
    display: "flex",
    gap: 8,
    overflowX: "auto",
    paddingBottom: 8,
    marginBottom: 10,
  },

  roundBtn: {
    minWidth: 40,
    height: 36,
